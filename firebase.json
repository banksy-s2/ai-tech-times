{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "docs",
    "ignore": ["firebase.json", "**/.*"],
    "cleanUrls": false,
    "headers": [
      {
        "source": "**/*.@(html|json|xml|txt)",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      }
    ]
  }
}
