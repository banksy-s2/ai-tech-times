rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // いいね: 誰でも読める。書き込みは「+1ずつ」だけ許可(改ざん・一括操作の防止)
    match /likes/{article} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['count', 'title', 'path', 'cat'])
        && request.resource.data.count == 1;
      allow update: if request.resource.data.keys().hasOnly(['count', 'title', 'path', 'cat'])
        && request.resource.data.count == resource.data.count + 1;
    }
  }
}
